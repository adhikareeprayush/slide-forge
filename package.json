{
  "name": "slideforge",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "db:up": "docker compose up -d postgres minio",
    "db:setup": "node scripts/wait-for-postgres.mjs && pnpm --filter api db:push && pnpm --filter api db:seed",
    "infra:up": "node scripts/infra-up.mjs",
    "infra:redis": "docker compose up -d redis",
    "github:labels": "node scripts/sync-github-labels.mjs",
    "github:issues": "node scripts/sync-github-labels.mjs && node scripts/create-github-issues.mjs"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
