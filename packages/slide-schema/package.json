{
    "name": "@slideforge/schema",
    "version": "0.0.1",
    "private": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      }
    },
    "scripts": {
      "build": "tsup src/index.ts --format esm,cjs --dts",
      "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
      "lint": "eslint src/",
      "typecheck": "tsc --noEmit",
      "test": "vitest run"
    },
    "devDependencies": {
      "tsup": "^8.0.0",
      "typescript": "^5.4.0",
      "vitest": "^3.0.0"
    },
    "dependencies": {
      "zod": "^3.23.0"
    }
  }