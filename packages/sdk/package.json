{
    "name": "@slideforge/sdk",
    "version": "0.0.1",
    "private": false,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "bin": {
      "slideforge": "./dist/cli.js"
    },
    "scripts": {
      "build": "tsup src/index.ts src/cli.ts --format esm --dts",
      "dev": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --watch",
      "lint": "eslint src/",
      "typecheck": "tsc --noEmit"
    },
    "dependencies": {
      "@slideforge/schema": "workspace:*",
      "commander": "^12.0.0",
      "jiti": "^2.4.0",
      "picocolors": "^1.0.0",
      "vite": "^6.0.0",
      "@vitejs/plugin-react": "^4.3.0"
    },
    "devDependencies": {
      "@types/node": "^22.15.3",
      "react": "^19.0.0",
      "react-dom": "^19.0.0",
      "tsup": "^8.0.0",
      "typescript": "^5.4.0"
    }
  }