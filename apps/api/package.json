    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "express": "^5.0.1",
    "ioredis": "^5.4.0",
    "jiti": "^2.4.0",
    "openai": "^4.77.0",
    "pdf-lib": "^1.17.1",
    "postgres": "^3.4.5",
