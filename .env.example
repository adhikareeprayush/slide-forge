# SlideForge environment variables

# ─── Phase 1: Core (required for preview) ───
DATABASE_URL=postgresql://slideforge:slideforge@localhost:5432/slideforge
PORT=4000
CORS_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── Phase 2: Infrastructure ───
# Use 6379 if you have system Redis (common on Arch). Use 6380 for Docker Redis (pnpm infra:redis).
REDIS_URL=redis://localhost:6379
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_PUBLIC_URL=http://localhost:9000/slideforge
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=slideforge
STORAGE_REGION=us-east-1

# ─── Phase 2: AI (human checkpoint) ───
# Use "mock" for local dev without API keys, "nvidia" for real generation
AI_PROVIDER=mock
# NVIDIA_API_KEY=nvapi-xxxxxxxxxxxx
# NVIDIA_TEXT_MODEL=meta/llama-3.1-70b-instruct
# NVIDIA_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Images: "stock" uses Unsplash/Picsum (fast, reliable). "nvidia" tries SDXL first.
IMAGE_SOURCE=stock
# Set to "true" to upload images to MinIO; default uses direct URLs (works without MinIO)
# IMAGE_UPLOAD=true
# Optional — better photo matching (free at https://unsplash.com/developers)
# UNSPLASH_ACCESS_KEY=

# ─── Phase 2: Limits ───
MAX_GENERATIONS_PER_HOUR=10
DEFAULT_SLIDE_COUNT=8
RUN_IMAGE_WORKER=true

# ─── Phase 3+: Auth ───
# AUTH_SECRET=generate-with-openssl-rand-base64-32
# AUTH_URL=http://localhost:3000
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=
